FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends openssh-client \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY pyproject.toml ./
COPY src ./src
RUN pip install --no-cache-dir .

COPY docker-entrypoint-betfair.sh /usr/local/bin/docker-entrypoint-betfair.sh
RUN chmod +x /usr/local/bin/docker-entrypoint-betfair.sh

ENV PYTHONUNBUFFERED=1
ENTRYPOINT ["/usr/local/bin/docker-entrypoint-betfair.sh"]
